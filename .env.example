# ─── Google Drive ────────────────────────────────────────────────────────────
# Path to your downloaded Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# The ID of the Google Drive folder you shared with your service account
# Get it from the URL: drive.google.com/drive/folders/<THIS_ID>
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# ─── Groq LLM ────────────────────────────────────────────────────────────────
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── Groq Model ──────────────────────────────────────────────────────────────
# Available fast models: llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ─── FAISS / Storage ─────────────────────────────────────────────────────────
FAISS_INDEX_PATH=faiss_index.bin
METADATA_PATH=metadata.json

# ─── Embedding Model ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ─── RAG Settings ────────────────────────────────────────────────────────────
# Number of top chunks to retrieve from FAISS for each query
TOP_K_RESULTS=5

# ─── Chunking Settings ───────────────────────────────────────────────────────
CHUNK_SIZE=400       # words per chunk
CHUNK_OVERLAP=50     # overlapping words between consecutive chunks
